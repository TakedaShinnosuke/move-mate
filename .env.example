# ===========================================
# move-mate 環境変数テンプレート
# ===========================================
# このファイルをコピーして .env を作成し、各値を設定してください。
#   cp .env.example .env
# .env は絶対にコミットしないこと（.gitignore で除外済み）。
# 実値はチームの Discord #secrets で共有します。

# --- Supabase ---
# Supabase ダッシュボード > Project Settings > Data API から取得
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Maps Platform ---
# GCP Console > APIs & Services > Credentials の API キー
# 有効化済み: Maps SDK (Android/iOS), Directions API, Places API, Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Anthropic Claude API ---
# 筋トレAI提案機能で使用。Anthropic Console > API Keys から取得
# 注意: サーバーサイド/Edge Function で使う想定。クライアントに直接埋め込まない方針
ANTHROPIC_API_KEY=